        {
            "id": "grp_team_confirm",
            "title": "Confirmar Equipo",
            "graphCoordinates": {
                "x": 2000,
                "y": 400
            },
            "blocks": [
                {
                    "id": "blk_team_confirm_text",
                    "type": "text",
                    "content": {
                        "richText": [
                            {
                                "type": "p",
                                "children": [
                                    {
                                        "text": "✅ Te conectamos con el equipo "
                                    },
                                    {
                                        "bold": true,
                                        "text": "{{selected_team_name}}"
                                    },
                                    {
                                        "text": ". Te atenderán en breve 🙌"
                                    }
                                ]
                            },
                            {
                                "type": "p",
                                "children": [
                                    {
                                        "text": "[MEGA_CMD:assign_team:{{selected_team_id}}]"
